}

rectangle "CAMADA DE INTELIGÊNCIA" as L_AI #F5F3FF {
  rectangle "OpenAI gpt-4o-mini\ntemperature=0\nextração · classificação · decisão" as AI
}

rectangle "CAMADA DE PROTOCOLO" as L_PROTO #FEF9C3 {
  rectangle "MCP Client\nlangchain-mcp-adapters\nTranslates LangChain ↔ MCP" as MC
  rectangle "stdio transport\nsubprocesso isolado" as STDIO
  rectangle "MCP Server (FastMCP)\n7 tools · validação Pydantic\nsoft delete · audit log" as MS
}

rectangle "CAMADA DE DADOS" as L_DATA #FEE2E2 {
  rectangle "SQLite (financas.db)\nexpenses · categories · audit_log" as DB
}

rectangle "OBSERVABILIDADE" as L_OBS #F0FDF4 {
  rectangle "LangSmith\nauto-tracing via env vars\nproject: financas-ia-mvp1" as LS
}

MAIN  -down-> LG
LG    -down-> AI   : chamadas LLM
LG    -down-> MC   : tool calls
