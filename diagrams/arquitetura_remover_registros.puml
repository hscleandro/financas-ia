@startuml Fluxo_HITL_Delete_Sem_Data
title Fluxo HITL — Exclusão SEM data explícita\n"apaga o almoço"

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam backgroundColor #FAFAFA
skinparam participantBackgroundColor #EEF2FF
skinparam participantBorderColor #6366F1
skinparam sequenceArrowColor #6366F1
skinparam noteBackgroundColor #FEF9C3
skinparam noteBorderColor #D97706

actor       "Usuário"                       as U
participant "LangGraph\nAgente"             as AG
participant "MCP Server\n(find_expense_candidates)" as MS
database    "SQLite"                        as DB

U  -> AG : "apaga o almoço"

note over AG #EEF2FF
  Sem referência temporal detectada.
  Não passa expense_date.
end note

AG -> MS : find_expense_candidates\n(keyword="almoço")

MS -> DB : SELECT MAX(expense_date)\nFROM expenses\nWHERE description LIKE '%almoco%'\nAND deleted_at IS NULL
DB --> MS : 2026-05-12

MS -> DB : SELECT * FROM expenses\nWHERE description LIKE '%almoco%'\nAND expense_date = '2026-05-12'\nAND deleted_at IS NULL
DB --> MS : [{id:3, R$55, almoço, 12/05}, {id:4, R$42, almoço pf, 12/05}]

MS --> AG : {keyword:"almoço", date_searched:"2026-05-12",\ntotal_found:2, records:[...]}

note over AG #FEF9C3
  Múltiplos registros na data mais recente.
  Deve listar e pedir escolha.
  NÃO chama delete_expense.
end note

AG --> U : "Encontrei 2 registros de 'almoço' em 12/05/2026:\n\n  #3 · R$ 55,00 · Alimentação · dinheiro\n  #4 · R$ 42,00 · almoço pf  · Alimentação · pix\n\nQual deseja excluir?"

U  -> AG : "o segundo"

note over AG #FEF9C3
  Identificou registro #4.
  Ainda NÃO chama delete_expense.
  Deve mostrar detalhes e pedir confirmação.
end note

AG --> U : "Você solicitou a exclusão do registro:\n\n  ID #4 · R$ 42,00 · almoço pf\n  Alimentação · pix · 12/05/2026\n\nTem certeza? (sim/não)"

U  -> AG : "sim"

note over AG #D1FAE5
  Confirmação explícita na mensagem ATUAL.
  Passa confirmed=True.
end note

AG -> MS : delete_expense(expense_id=4, confirmed=True)
MS -> DB : UPDATE expenses SET deleted_at=NOW() WHERE id=4
MS -> DB : INSERT INTO audit_log (delete, 4, old_data_json)
DB --> MS : OK
MS --> AG : {deleted:true, expense_id:4, record:{...}}

AG --> U : "✓ Registro #4 excluído:\nR$ 42,00 · almoço pf · 12/05/2026"

@enduml


